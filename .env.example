# HyperSussy Configuration
# Copy to .env and adjust as needed.
# All values have sensible defaults -- only set what you want to override.

# HYPERSUSSY_LOG_LEVEL=INFO
# HYPERSUSSY_DB_PATH=data/hypersussy.db

# Comma-separated list of coins to watch (empty = all listed perps)
# HYPERSUSSY_WATCHED_COINS=["BTC","ETH","SOL"]

# OI Concentration thresholds
# HYPERSUSSY_OI_CHANGE_PCT_THRESHOLD=0.10
# HYPERSUSSY_OI_CONCENTRATION_THRESHOLD=0.20

# Whale tracker
# HYPERSUSSY_WHALE_VOLUME_THRESHOLD_USD=500000
# HYPERSUSSY_MAX_TRACKED_ADDRESSES=200
